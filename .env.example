PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Stripe (mode test) — substitueix pel valor real del teu Dashboard de Stripe,
# mai el deixis amb un valor real commitejat al repositori
STRIPE_SECRET_KEY=sk_test_REPLACA_AQUI_LA_TEVA_CLAU_SECRETA
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACA_AQUI_LA_TEVA_CLAU_PUBLICA
STRIPE_WEBHOOK_SECRET=whsec_REPLACA_AQUI_EL_TEU_SECRET_DE_WEBHOOK
CHECKOUT_EXPIRES_MINUTES=15

# Base de dades (Supabase / Postgres)
# Copia-la des del teu projecte Supabase: Project Settings > Database > Connection string > URI
# (recomanat: la "Connection pooling" / Transaction pooler, port 6543, per a connexions externes)
DATABASE_URL=postgresql://postgres:LA-TEVA-CONTRASENYA@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Accés bàsic (reservat per al futur panell d'administració)
ADMIN_USER=admin
ADMIN_PASS=canvia-aquesta-contrasenya

# Secret per signar la cookie de sessió del panell d'administració (HMAC-SHA256).
# Genera'n un de llarg i aleatori, per exemple amb: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=canvia-aquest-secret-per-un-de-llarg-i-aleatori
